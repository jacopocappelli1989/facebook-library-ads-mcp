# Your Facebook Graph API access token.
# Get one from https://developers.facebook.com/tools/explorer/ with `ads_read` scope.
FB_ACCESS_TOKEN=your_facebook_access_token_here

# (optional) Override Graph API version. Default: v21.0
FB_GRAPH_API_VERSION=v21.0

# (optional) Override cache directory. Default: ~/.facebook-ads-library-mcp
# FB_ADS_CACHE_DIR=/path/to/cache
